#!/usr/bin/env bash
# healthfire - dev workflow wrapper.
#
# The build runs in Docker, so no JDK or Android SDK is needed on the host.
# Device commands use the host's adb: a Docker Desktop container cannot reach
# a LAN-attached phone, but the host can (and does mDNS discovery natively).
set -euo pipefail

APK_PATH="app/build/outputs/apk/debug/app-debug.apk"
RELEASE_APK_PATH="app/build/outputs/apk/release/app-release.apk"
PKG="io.github.viyh.healthfire"

# Serial of the connected phone. Picked explicitly so a command still works
# when adb briefly lists the phone under more than one transport (mDNS).
device_serial() {
  adb devices | awk -F'\t' '$2 == "device" { print $1; exit }'
}

# Run adb against the connected phone.
dadb() {
  local serial
  serial="$(device_serial)"
  if [ -z "$serial" ]; then
    echo "No phone connected. Enable Wireless debugging, then:" >&2
    echo "  ./healthfire connect <ip:port>   (ip:port is shown on the phone)" >&2
    exit 1
  fi
  adb -s "$serial" "$@"
}

case "${1:-help}" in
  build)
    docker compose run --rm build
    ;;
  release)
    docker compose run --rm build gradle --no-daemon assembleRelease
    ls -lh "$RELEASE_APK_PATH"
    ;;
  test)
    docker compose run --rm build gradle --no-daemon testDebugUnitTest
    ;;
  clean)
    docker compose run --rm build gradle --no-daemon clean
    ;;
  shell)
    docker compose run --rm build bash
    ;;
  connect)
    # usage: ./healthfire connect [ip:port]
    # With no argument, relies on adb's mDNS auto-discovery.
    if [ -n "${2:-}" ]; then
      adb connect "$2"
    else
      adb start-server >/dev/null 2>&1 || true
      sleep 1
      adb devices
    fi
    ;;
  disconnect)
    adb disconnect
    ;;
  pair)
    # usage: ./healthfire pair <ip:port> <code>
    adb pair "$2" "$3"
    ;;
  devices)
    adb devices
    ;;
  install)
    dadb install -r "$APK_PATH"
    ;;
  release-install)
    dadb install -r "$RELEASE_APK_PATH"
    ;;
  start)
    dadb shell am start -n "$PKG/.MainActivity"
    ;;
  run)
    docker compose run --rm build
    dadb install -r "$APK_PATH"
    dadb shell am start -n "$PKG/.MainActivity"
    ;;
  release-run)
    docker compose run --rm build gradle --no-daemon assembleRelease
    dadb install -r "$RELEASE_APK_PATH"
    dadb shell am start -n "$PKG/.MainActivity"
    ;;
  uninstall)
    dadb uninstall "$PKG" || true
    ;;
  logcat)
    dadb logcat -v color \
      Healthfire:V \
      HealthConnect:W HealthConnectClient:W \
      WM-WorkerWrapper:I WorkManager:I \
      Firebase:W FirebaseStorage:W FirebaseAuth:W \
      AndroidRuntime:E System.err:W \
      "*:S"
    ;;
  logcat-pid)
    pid="$(dadb shell pidof "$PKG" | tr -d '\r\n')"
    if [ -z "$pid" ]; then
      echo "App not running. Launch it first: ./healthfire start" >&2
      exit 1
    fi
    dadb logcat -v color --pid "$pid"
    ;;
  logcat-all)
    dadb logcat -v color
    ;;
  down)
    docker compose down
    ;;
  *)
    cat <<EOF
healthfire dev workflow

The build runs in Docker. Device commands use the host's adb.

Build (Docker):
  ./healthfire build               build the debug APK
  ./healthfire release             build the release APK
  ./healthfire test                run JVM unit tests
  ./healthfire clean               gradle clean
  ./healthfire shell               shell into the build container

Device (host adb):
  ./healthfire connect [ip:port]   connect to the phone (Wireless debugging)
  ./healthfire pair <ip:port> <code>   pair with the phone
  ./healthfire run                 build + install + launch (debug)
  ./healthfire release-run         build + install + launch (release)
  ./healthfire install             install the last-built debug APK
  ./healthfire release-install     install the last-built release APK
  ./healthfire start               launch the app on the phone
  ./healthfire devices             list connected devices
  ./healthfire logcat              stream filtered logs
  ./healthfire logcat-pid          stream logs from the app process only
  ./healthfire logcat-all          stream everything (noisy)
  ./healthfire uninstall           uninstall from the phone
  ./healthfire disconnect          disconnect all adb devices
  ./healthfire down                stop Docker Compose
EOF
    ;;
esac
